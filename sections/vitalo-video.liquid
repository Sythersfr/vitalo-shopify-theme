<section class="vitalo-video" style="padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  <div class="vitalo-video__container">
    {% if section.settings.heading != blank %}
      <h2 class="vitalo-video__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="vitalo-video__wrapper">
      <video
        class="vitalo-video__player"
        {% if section.settings.loop %}loop{% endif %}
        playsinline
        preload="auto"
      >
        <source src="{{ 'vitalo-promo.mp4' | asset_url }}" type="video/mp4">
        Your browser does not support the video tag.
      </video>

      <button class="vitalo-video__toggle" aria-label="Play video">
        <svg class="vitalo-video__icon vitalo-video__icon--play" width="100" height="100" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="50" cy="50" r="50" fill="rgba(26, 46, 31, 0.7)"/>
          <polygon points="38,25 78,50 38,75" fill="white"/>
        </svg>
        <svg class="vitalo-video__icon vitalo-video__icon--pause" width="100" height="100" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="50" cy="50" r="50" fill="rgba(26, 46, 31, 0.7)"/>
          <rect x="33" y="28" width="12" height="44" rx="3" fill="white"/>
          <rect x="55" y="28" width="12" height="44" rx="3" fill="white"/>
        </svg>
      </button>
    </div>

  </div>
</section>

<style>
  .vitalo-video {
    background: var(--vitalo-cream, #FAF8F5);
  }

  .vitalo-video__container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
    text-align: center;
  }

  .vitalo-video__heading {
    font-family: var(--font-heading, 'Playfair Display', Georgia, serif);
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 700;
    color: var(--vitalo-dark, #2D3A2E);
    margin-bottom: 32px;
    line-height: 1.2;
  }

  .vitalo-video__wrapper {
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.12);
    background: var(--vitalo-green-deep, #1A2E1F);
    cursor: pointer;
  }

  .vitalo-video__player {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .vitalo-video__toggle {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: none;
    border: none;
    cursor: pointer;
    z-index: 2;
    padding: 0;
    line-height: 0;
    transition: opacity 0.35s ease, transform 0.35s ease;
  }

  .vitalo-video__toggle:hover {
    transform: translate(-50%, -50%) scale(1.08);
  }

  .vitalo-video__icon {
    filter: drop-shadow(0 4px 20px rgba(0, 0, 0, 0.3));
  }

  .vitalo-video__icon--pause {
    display: none;
  }

  .vitalo-video__wrapper.is-playing .vitalo-video__icon--play {
    display: none;
  }

  .vitalo-video__wrapper.is-playing .vitalo-video__icon--pause {
    display: block;
  }

  .vitalo-video__wrapper.is-playing .vitalo-video__toggle {
    opacity: 0;
  }

  .vitalo-video__wrapper.is-playing:hover .vitalo-video__toggle {
    opacity: 1;
  }

  @media (max-width: 749px) {
    .vitalo-video__icon--play,
    .vitalo-video__icon--pause {
      width: 72px;
      height: 72px;
    }
  }
</style>

<script>
  (function() {
    var wrapper = document.querySelector('.vitalo-video__wrapper');
    if (!wrapper) return;
    var video = wrapper.querySelector('.vitalo-video__player');
    var btn = wrapper.querySelector('.vitalo-video__toggle');
    if (!video || !btn) return;

    video.currentTime = 0.001;

    function togglePlay() {
      if (video.paused) {
        video.play();
      } else {
        video.pause();
      }
    }

    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      togglePlay();
    });

    wrapper.addEventListener('click', function(e) {
      if (e.target === btn || btn.contains(e.target)) return;
      togglePlay();
    });

    video.addEventListener('play', function() {
      wrapper.classList.add('is-playing');
      btn.setAttribute('aria-label', 'Pause video');
    });

    video.addEventListener('pause', function() {
      wrapper.classList.remove('is-playing');
      btn.setAttribute('aria-label', 'Play video');
    });
  })();
</script>

{% schema %}
{
  "name": "Vitalo Video",
  "tag": "section",
  "class": "vitalo-video-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See What Makes Us Different"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Vitalo Video"
    }
  ]
}
{% endschema %}
