  }
  .vsp-narrow {
    max-width: 640px;
    margin: 0 auto;
  }

  .vsp h2 {
    font-family: var(--font-heading);
    font-size: clamp(26px, 4vw, 38px);
    color: var(--vitalo-dark);
    line-height: 1.2;
    margin-bottom: var(--space-lg);
    font-weight: 700;
  }
  .vsp h3 {
    font-family: var(--font-heading);
    font-size: 22px;
    color: var(--vitalo-dark);
    margin-bottom: 12px;
    font-weight: 700;
  }
  .vsp p {
    margin-bottom: 20px;
    font-size: 18px;
    line-height: 1.7;
  }
  .vsp p:last-child { margin-bottom: 0; }

  .vsp-eyebrow {
    font-size: 13px;
    color: var(--vitalo-gold);
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 14px;
  }
  .vsp-strong {
    color: var(--vitalo-dark);
    font-weight: 600;
  }
  .vsp-muted { color: var(--vitalo-text-light); }
  .vsp-gold { color: var(--vitalo-gold); }

  .vsp-divider {
    width: 40px;
    height: 2px;
    background: var(--vitalo-gold);
    margin: 40px 0;
  }

  .vsp blockquote {
    border-left: 3px solid var(--vitalo-gold);
    padding: 16px 24px;
    margin: 28px 0;
    background: var(--vitalo-cream);
    font-style: italic;
    font-size: 17px;
    color: var(--vitalo-text);
  }
  .vsp .vsp-section--dark blockquote {
    background: rgba(74,124,89,0.12);
    color: #FAF8F5 !important;
  }

  .vsp-check-list {
    list-style: none;
    padding: 0;
    margin: 24px 0;
  }
  .vsp-check-list li {
    padding: 10px 0 10px 32px;
    position: relative;
    font-size: 17px;
  }
  .vsp-check-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--vitalo-green);
    font-weight: 700;
    font-size: 18px;
  }
  .vsp .vsp-section--dark .vsp-check-list li::before {
    color: #C9A84A !important;
  }
  .vsp .vsp-section--dark .vsp-check-list li {
    color: #FAF8F5 !important;
  }

