{{ 'vitalo-custom.css' | asset_url | stylesheet_tag }}

<section class="vitalo-bundles">
  <div class="vitalo-bundles__inner">
    <div class="vitalo-bundles__header vitalo-animate">
      <h2 class="vitalo-bundles__title">{{ section.settings.heading }}</h2>
      <p class="vitalo-bundles__subtitle">{{ section.settings.subheading }}</p>
    </div>

    <div class="vitalo-bundles__grid">
      {% for block in section.blocks %}
        {% assign original_cents = block.settings.original_price | times: 100 %}
        {% assign bundle_cents = block.settings.bundle_price | times: 100 %}
        {% assign savings_cents = original_cents | minus: bundle_cents %}
        {% assign savings_dollars = savings_cents | divided_by: 100.0 %}

        <div class="vitalo-bundle-card vitalo-animate vitalo-animate-delay-{{ forloop.index }}" {{ block.shopify_attributes }}>
          {% if block.settings.badge != blank %}
            <span class="vitalo-bundle-card__badge">{{ block.settings.badge }}</span>
          {% endif %}

          <div class="vitalo-bundle-card__body">
            <h3 class="vitalo-bundle-card__name">{{ block.settings.title }}</h3>

            {% if block.settings.description != blank %}
              <p class="vitalo-bundle-card__desc">{{ block.settings.description }}</p>
            {% endif %}

            <div class="vitalo-bundle-card__products">
              {% for i in (1..5) %}
                {% assign prod_key = 'product_' | append: i %}
                {% assign prod = block.settings[prod_key] %}
                {% if prod != blank %}
                  <div class="vitalo-bundle-card__product">
                    <div class="vitalo-bundle-card__product-img">
                      {% if prod.featured_image %}
                        <img
                          src="{{ prod.featured_image | image_url: width: 120 }}"
                          alt="{{ prod.featured_image.alt | default: prod.title | escape }}"
                          width="120"
                          height="120"
                          loading="lazy"
                        >
                      {% else %}
                        {{ 'product-1' | placeholder_svg_tag }}
                      {% endif %}
                    </div>
                    <span class="vitalo-bundle-card__product-name">{{ prod.title | truncate: 20 }}</span>
                  </div>
                {% endif %}
              {% endfor %}
            </div>

            <div class="vitalo-bundle-card__pricing">
              {% if savings_cents > 0 %}
                <span class="vitalo-bundle-card__price-original">${{ block.settings.original_price | money_without_currency }}</span>
              {% endif %}
              <span class="vitalo-bundle-card__price-bundle">${{ block.settings.bundle_price | money_without_currency }}</span>
              {% if savings_cents > 0 %}
                <span class="vitalo-bundle-card__savings">Save ${{ savings_dollars | money_without_currency }}</span>
              {% endif %}
            </div>

            {% assign bundle_link = block.settings.bundle_link | default: block.settings.product_1.url %}
            {% if bundle_link != blank %}
              <a href="{{ bundle_link }}" class="vitalo-bundle-card__cta">
                {{ block.settings.cta_label | default: 'Shop This Bundle' }}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.button_label != blank %}
      <div style="text-align: center; margin-top: var(--space-2xl);">
        <a href="{{ section.settings.button_link }}" class="button button--secondary">
          {{ section.settings.button_label }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Vitalo Bundles",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Performance Bundles"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Save more when you stack. Curated bundles designed to work together for complete daily support."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "View All Button Label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "View All Button Link"
    }
  ],
  "blocks": [
    {
      "type": "bundle",
      "name": "Bundle",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Bundle Name",
          "default": "Wellness Bundle"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Complete daily coverage for adults 50+."
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge Label",
          "info": "e.g. Best Value, Most Popular. Leave blank for no badge."
        },
        {
          "type": "product",
          "id": "product_1",
          "label": "Product 1"
        },
        {
          "type": "product",
          "id": "product_2",
          "label": "Product 2"
        },
        {
          "type": "product",
          "id": "product_3",
          "label": "Product 3"
        },
        {
          "type": "product",
          "id": "product_4",
          "label": "Product 4"
        },
        {
          "type": "product",
          "id": "product_5",
          "label": "Product 5"
        },
        {
          "type": "text",
          "id": "original_price",
          "label": "Original Price",
          "info": "Sum of individual products (e.g. 224.96)"
        },
        {
          "type": "text",
          "id": "bundle_price",
          "label": "Bundle Price",
          "info": "Discounted bundle price (e.g. 180.00)"
        },
        {
          "type": "url",
          "id": "bundle_link",
          "label": "Bundle Link",
          "info": "Link to the bundle product page. Falls back to Product 1 if blank."
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Button Label",
          "default": "Shop This Bundle"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Vitalo Bundles"
    }
  ]
}
{% endschema %}
